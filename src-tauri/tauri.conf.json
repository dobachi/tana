{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Tana",
  "version": "0.1.0",
  "identifier": "com.dobachi.tana",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run build:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tana",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "browserExtensionsEnabled": false,
        "devtools": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "required": false,
          "description": "Path to a directory to open"
        }
      ]
    }
  }
}
